{
  "expo": {
    "name": "MM Laundry",
    "slug": "laundry_mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon-laundry.png",
    "scheme": "laundrymobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.zakiyzd.laundry_mobile",
      "versionCode": 3,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ],
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#D2E9FF",
        "foregroundImage": "./assets/images/android-icon-foreground-laundry2.png"
      },
      "splash": {
        "image": "./assets/images/splash-laundryfix.png",
        "resizeMode": "contain",
        "backgroundColor": "#D2E9FF"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-laundryfix.png",
          "resizeMode": "contain",
          "backgroundColor": "#D2E9FF"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "750a276a-333a-4c55-9b3c-c17ee7d219ed"
      }
    }
  }
}
